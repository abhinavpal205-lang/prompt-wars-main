# --- OpenAI -----------------------------------------------------------------
# Optional. Leave blank to run in offline stub mode (form check-in fully works;
# voice mode is disabled and AI reflections fall back to curated messages).
OPENAI_API_KEY=

# --- App --------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000

# Encryption key for the free-note field at rest (Fernet, urlsafe base64).
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to use an ephemeral key (notes won't decrypt across restarts).
FERNET_KEY=

# --- Email (parent/guardian notifications) -----------------------------------
# Optional. Leave all blank to use the console stub: notification emails are
# printed to backend logs instead of being sent.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
